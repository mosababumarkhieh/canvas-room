# Database - get a free connection string from neon.tech or supabase.com
DATABASE_URL="postgresql://user:password@host:5432/canvasroom?sslmode=require"

# Session secret - run: openssl rand -base64 32
SESSION_SECRET="replace-with-a-random-32-character-secret"

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Socket.IO server URL — only needed when the socket server runs separately
# from the Next.js app (e.g. full app on Vercel, socket server on Railway).
# Leave empty when running locally or when everything runs on one server.
NEXT_PUBLIC_SOCKET_URL=""
